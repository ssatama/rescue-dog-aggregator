# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Distribution / packaging
dist/
build/
*.egg-info/

# Virtual environments
venv/
env/
ENV/

# Jupyter Notebook
.ipynb_checkpoints
exploration/.ipynb_checkpoints/

# Local data files (ignore all files in data/, but keep the directory via .gitkeep)
data/*
!data/.gitkeep

# Environment variables
.env
.env.local

# IDE specific files
.idea/
.vscode/
*.swp
*.swo

# Testing artifacts
.coverage
coverage/
htmlcov/
.pytest_cache/
test-results/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Frontend build artifacts
frontend/.next/
frontend/out/
frontend/build/
frontend/node_modules/